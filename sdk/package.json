{
  "name": "@yellow-org/contracts",
  "version": "1.0.3",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./abi/*.json": "./abi/*.json"
  },
  "description": "Typed ABIs and deployed addresses for Yellow Network smart contracts",
  "repository": {
    "type": "git",
    "url": "https://github.com/layer-3/yellow",
    "directory": "sdk"
  },
  "license": "GPL-3.0-or-later",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "abi",
    "README.md"
  ],
  "scripts": {
    "extract": "bun run ../script/extract-abis.ts && bun run ../script/extract-addresses.ts",
    "build": "bun run extract && tsup",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6",
    "tsup": "^8",
    "typescript": "^5"
  }
}
