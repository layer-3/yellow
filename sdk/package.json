{
  "name": "@yellow-org/contracts",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "extract": "bun run ../script/extract-abis.ts",
    "build": "bun run extract && tsup",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "tsup": "^8",
    "typescript": "^5"
  }
}
